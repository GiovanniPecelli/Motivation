# Supabase Configuration
# Copy this file to .env and fill in your actual values

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Database Configuration (for scripts only)
# Get from Supabase Dashboard > Settings > Database
SUPABASE_DB_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-1-eu-west-1.pooler.supabase.com:5432/postgres

# Cloudinary Configuration
# Get from Cloudinary Dashboard > Settings > API Keys
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_API_KEY=your_api_key_here
VITE_CLOUDINARY_API_SECRET=your_api_secret_here
